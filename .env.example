# Plantilla de configuración. Copia este fichero como `.env` y rellena con
# tus propias claves. Necesitas al menos UNA de las dos para que la app
# funcione (Mistral, Groq, o ambas si quieres comparar entre proveedores).
#
# Obtención:
#   - Mistral AI: https://console.mistral.ai/api-keys
#   - Groq:       https://console.groq.com/keys
#
# El fichero `.env` está excluido de git por seguridad.

GROQ_API_KEY=tu_clave_groq_aqui
MISTRAL_API_KEY=tu_clave_mistral_aqui
